{
    // =========================================================================
    // ZEN VISUAL SETTINGS
    // =========================================================================

    // Theme
    "workbench.colorTheme": "Catppuccin Mocha",
    "workbench.iconTheme": "catppuccin-mocha",
    "workbench.productIconTheme": "catppuccin-mocha",

    // Font
    "editor.fontFamily": "'JetBrains Mono', 'JetBrainsMono Nerd Font', monospace",
    "editor.fontSize": 14,
    "editor.lineHeight": 1.6,
    "editor.fontLigatures": true,
    "editor.fontWeight": "400",

    // Cursor
    "editor.cursorStyle": "line",
    "editor.cursorBlinking": "smooth",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorWidth": 2,

    // Smooth scrolling
    "editor.smoothScrolling": true,
    "workbench.list.smoothScrolling": true,
    "terminal.integrated.smoothScrolling": true,

    // =========================================================================
    // MINIMAL UI - Zen Mode Defaults
    // =========================================================================

    // Hide activity bar (use Cmd+Shift+E, Cmd+Shift+F, etc.)
    "workbench.activityBar.location": "hidden",

    // Single tab only - reduces visual noise
    "workbench.editor.showTabs": "single",
    "workbench.editor.tabSizing": "shrink",

    // Hide clutter
    "editor.minimap.enabled": false,
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.horizontal": "hidden",
    "editor.overviewRulerBorder": false,
    "breadcrumbs.enabled": false,
    "editor.renderLineHighlight": "gutter",
    "editor.guides.indentation": false,
    "window.commandCenter": false,
    "workbench.layoutControl.enabled": false,
    "editor.glyphMargin": false,
    "editor.folding": true,
    "editor.foldingHighlight": false,

    // Status bar stays (useful for git, line info)
    "workbench.statusBar.visible": true,

    // =========================================================================
    // ZEN MODE CONFIGURATION
    // =========================================================================

    "zenMode.fullScreen": false,
    "zenMode.hideLineNumbers": false,
    "zenMode.hideStatusBar": false,
    "zenMode.centerLayout": true,
    "zenMode.silentNotifications": true,
    "zenMode.restore": true,

    // =========================================================================
    // AI CONFIGURATION (Cursor-specific)
    // =========================================================================

    // Enable advanced features
    "cursor.cpp.enablePartialAccepts": true,
    "cursor.chat.showSuggestedFiles": true,
    "cursor.general.enableShadowWorkspace": true,

    // Inline suggestions
    "editor.inlineSuggest.enabled": true,
    "editor.inlineSuggest.showToolbar": "onHover",
    "editor.acceptSuggestionOnEnter": "smart",

    // =========================================================================
    // EDITOR BEHAVIOR
    // =========================================================================

    // Auto-save (important for AI workflows - changes persist)
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,

    // Clean files
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,

    // Editor behavior
    "editor.wordWrap": "on",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": false,
    "editor.linkedEditing": true,
    "editor.suggest.insertMode": "replace",
    "editor.bracketPairColorization.enabled": true,

    // =========================================================================
    // LANGUAGE-SPECIFIC SETTINGS (Your Stack)
    // =========================================================================

    "[powershell]": {
        "editor.defaultFormatter": "ms-vscode.powershell",
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.formatOnSave": true,
        "files.encoding": "utf8bom"
    },

    "[shellscript]": {
        "editor.defaultFormatter": "foxundermoon.shell-format",
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },

    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true,
        "editor.tabSize": 4
    },

    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 2
    },

    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 2
    },

    "[yaml]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.autoIndent": "advanced"
    },

    "[xml]": {
        "editor.tabSize": 2,
        "editor.autoClosingBrackets": "always"
    },

    "[markdown]": {
        "editor.wordWrap": "on",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": false
        }
    },

    // =========================================================================
    // TERMINAL
    // =========================================================================

    "terminal.integrated.fontFamily": "'JetBrains Mono'",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.lineHeight": 1.4,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.scrollback": 10000,

    // =========================================================================
    // GIT
    // =========================================================================

    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "git.openRepositoryInParentFolders": "always",
    "scm.diffDecorations": "gutter",
    "diffEditor.ignoreTrimWhitespace": false,

    // =========================================================================
    // FILE ASSOCIATIONS
    // =========================================================================

    "files.associations": {
        "*.ps1xml": "xml",
        "*.psd1": "powershell",
        "*.psm1": "powershell",
        "*.intunewin": "binary",
        "CLAUDE.md": "markdown"
    },

    // =========================================================================
    // EXCLUDED FILES (Performance)
    // =========================================================================

    "files.exclude": {
        "**/.git": true,
        "**/.DS_Store": true,
        "**/node_modules": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true
    },

    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true,
        "**/*.intunewin": true
    },

    // =========================================================================
    // EXTENSIONS BEHAVIOR
    // =========================================================================

    // PowerShell
    "powershell.codeFormatting.preset": "OTBS",
    "powershell.integratedConsole.showOnStartup": false,

    // Prettier
    "prettier.tabWidth": 2,
    "prettier.useTabs": false,
    "prettier.singleQuote": true,

    // =========================================================================
    // MISC
    // =========================================================================

    "workbench.startupEditor": "none",
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "security.workspace.trust.untrustedFiles": "open",
    "telemetry.telemetryLevel": "off",
    "update.mode": "manual",
    "zenMode.showTabs": "single"
}
