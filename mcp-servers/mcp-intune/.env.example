# Intune MCP Server Configuration
# Copy this to .env and fill in your values

# Required: Azure AD app registration credentials
# Create at: https://entra.microsoft.com > App registrations
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Optional: Cache TTL in seconds (default: 300)
INTUNE_CACHE_TTL=300

# Optional: Graph API version (default: v1.0)
GRAPH_API_VERSION=v1.0

# Optional: Transport (stdio or http)
TRANSPORT=stdio

# Optional: HTTP transport settings
SERVER_HOST=127.0.0.1
SERVER_PORT=8002
