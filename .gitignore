# Logs
*.log
Logs/
**/Logs/

# Temporary files
*.tmp
*.temp
*~

# Windows specific
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# PowerShell
*.ps1.bak
*.ps1.old

# Intune Win32 packages
*.intunewin
IntuneWinAppUtil.exe

# Source installers (keep structure, ignore binaries)
Deployments/*/Source/*.exe
Deployments/*/Source/*.msi
Deployments/*/Source/*.zip
Deployments/*/Source/*.msix
Deployments/*/Source/*.appx

# Keep Source directories but ignore contents
!Deployments/*/Source/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Testing
testing/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
.pytest_cache/
.coverage
htmlcov/

# Node
node_modules/

# Environment files (secrets)
.env
.env.local
.env.*.local
mcp-servers/*/.env

# MCP servers
mcp-servers/*/.pytest_cache/
mcp-servers/*/__pycache__/
