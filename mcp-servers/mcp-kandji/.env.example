# Kandji MCP Server Configuration
# Copy this to .env and fill in your values

# Required: Your Kandji tenant subdomain
# (the part before .kandji.io in your admin URL)
KANDJI_SUBDOMAIN=your-tenant

# Required: Kandji API token
# Generate at: Kandji Admin > Settings > Access > API Token
KANDJI_API_TOKEN=your-api-token-here

# Optional: Region (us or eu)
KANDJI_REGION=us

# Optional: Cache TTL in seconds (default: 300)
KANDJI_CACHE_TTL=300

# Optional: Transport (stdio or http)
TRANSPORT=stdio

# Optional: HTTP transport settings
SERVER_HOST=127.0.0.1
SERVER_PORT=8001
